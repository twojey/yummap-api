PORT=8000
# APP_ENV plutôt que DENO_ENV car Deno Deploy interdit les vars DENO_*.
APP_ENV=development
DEPLOY_MODE=all

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

GOOGLE_PLACES_API_KEY=your-google-places-key

OPENAI_API_KEY=your-openai-key
GEMINI_API_KEY=your-gemini-key

FCM_PROJECT_ID=your-fcm-project-id
FCM_SERVICE_ACCOUNT_KEY=your-fcm-service-account-json

VIDEO_STORAGE_PATH=/var/yummap/videos
VIDEO_STORAGE_URL=https://your-server.com/videos

# Telegram bot pour alertes admin (cookies Instagram expires, etc.).
# Cree le bot via @BotFather, recupere le chat_id via getUpdates.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
